# Component Rules

## Structure (in this order)
1. imports
2. type definitions
3. constants
4. component function
5. export

## Example
```tsx
import { useState } from "react"
import { Button } from "@/components/ui/button"

type UserCardProps = {
  id: number
  name: string
  onDelete: (id: number) => void
}

const MAX_NAME_LENGTH = 50 as const

const UserCard = ({ id, name, onDelete }: UserCardProps) => {
  const [isLoading, setIsLoading] = useState<boolean>(false)

  const handleDelete = async (): Promise<void> => {
    setIsLoading(true)
    await onDelete(id)
    setIsLoading(false)
  }

  return (
    <div className="rounded-lg border border-border bg-card p-4">
      <p className="text-foreground">{name}</p>
      <Button onClick={handleDelete} disabled={isLoading}>
        {isLoading ? "삭제 중..." : "삭제"}
      </Button>
    </div>
  )
}

export default UserCard
```

## Rules
- One component per file
- Props type defined directly above component
- Always explicitly type useState: `useState<number>(0)`
- Named exports for reusable components, default export for pages
- Always handle loading and error states
- Split into smaller components before file exceeds ~150 lines
- Keep state as local as possible — lift only when necessary
- No inline styles — Tailwind only
